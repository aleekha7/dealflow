# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Developers → API keys
STRIPE_SECRET_KEY=
# Stripe — Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe — the Price ID of the $15/mo "DealFlow Pro" recurring price (price_...)
STRIPE_PRICE_ID=

# Resend — API key for transactional email
RESEND_API_KEY=
# Optional: verified sender, e.g. "DealFlow <reminders@yourdomain.com>"
# Falls back to Resend's onboarding sender if unset (dev only).
RESEND_FROM_EMAIL=

# The canonical URL of this deployment (no trailing slash)
# e.g. http://localhost:3000 in dev, https://app.yourdomain.com in prod
NEXT_PUBLIC_APP_URL=

# Secret used to authenticate the daily reminder cron. Vercel Cron sends it
# automatically as "Authorization: Bearer <CRON_SECRET>" when set in Vercel env.
CRON_SECRET=
